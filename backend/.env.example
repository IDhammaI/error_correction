# ============================================================================
# Flask API 服务配置 SECRET_KEY必须配置!
# ============================================================================
SECRET_KEY=your-random-secret-key-change-this
# 开发模式开关（true 启用热重载和调试信息，生产环境务必设为 false）
FLASK_DEBUG=false

# ============================================================================
# LangSmith 配置（可选，用于调试追踪）
# ============================================================================
LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=你的_langsmith_api_key
# LANGSMITH_PROJECT="error-correction"

# ============================================================================
# 输出目录配置（可选）
# ============================================================================
# 目录配置由 config.py 集中管理（默认：backend/runtime_data/）
# 如需覆盖运行时输出的根目录，请设置 APP_RUNTIME_DIR（绝对路径）
# APP_RUNTIME_DIR=

# ============================================================================
# 文字擦除模型权重（可选）
# ============================================================================
# 默认路径：backend/models/weight/best.pth
# 如需指定其他位置，取消注释并填写绝对路径
# APP_MODEL_PATH=/path/to/your/best.pth

# ============================================================================
# 平台托管 Provider 默认配置（可选）
# 用户未配置自己的 provider 时，会回退到这里的默认服务并继续走免费额度逻辑。
# APP_DEFAULT_OPENAI_API_KEY=
# APP_DEFAULT_OPENAI_BASE_URL=
# APP_DEFAULT_OPENAI_MODEL_NAME=gpt-4o-mini
# APP_DEFAULT_OPENAI_LIGHT_MODEL_NAME=
# APP_DEFAULT_OPENAI_SUPPORTS_FUNCTION_CALLING=true
# APP_DEFAULT_ANTHROPIC_API_KEY=
# APP_DEFAULT_ANTHROPIC_BASE_URL=
# APP_DEFAULT_ANTHROPIC_MODEL_NAME=claude-sonnet-4-20250514
# APP_DEFAULT_PADDLEOCR_API_URL=
# APP_DEFAULT_PADDLEOCR_API_TOKEN=
# APP_DEFAULT_PADDLEOCR_MODEL=PaddleOCR-VL-1.5
# APP_DEFAULT_PADDLEOCR_USE_DOC_ORIENTATION=false
# APP_DEFAULT_PADDLEOCR_USE_DOC_UNWARPING=false
# APP_DEFAULT_PADDLEOCR_USE_CHART_RECOGNITION=false

# ============================================================================
# 验证码邮件 — SMTP 配置（注册验证码 + 找回密码共用）
#
# 【必填项】APP_SMTP_HOST / APP_SMTP_USER / APP_SMTP_PASSWORD / APP_SMTP_FROM
#   未填写时无法发送验证码邮件。
#   开发调试时可设置 FLASK_DEBUG=true，验证码会打印到后端日志，无需真实 SMTP。
#
# 【发件账号说明】
#   APP_SMTP_USER  — 发件邮箱地址（同时作为 SMTP 登录用户名）
#   APP_SMTP_FROM  — 邮件显示的发件人地址，通常与 USER 相同
#   APP_SMTP_PASSWORD — SMTP 授权码，不是邮箱登录密码！
#     · QQ 邮箱：邮箱设置 → 账户 → POP3/IMAP/SMTP → 开启服务 → 生成授权码
#     · 163 邮箱：设置 → POP3/SMTP/IMAP → 开启 → 设置客户端授权密码
#     · Gmail：需开启两步验证后生成「应用专用密码」
#
# 【端口与加密方式】
#   APP_SMTP_PORT=587 + APP_SMTP_USE_TLS=true  → STARTTLS（推荐，先明文握手再加密）
#   APP_SMTP_PORT=465 + APP_SMTP_USE_TLS=false → SSL/TLS（直连加密，代码自动切换 SMTP_SSL）
#
#   常用邮件服务商：
#     QQ 邮箱  smtp.qq.com      587(STARTTLS) 或 465(SSL)
#     163 邮箱 smtp.163.com     587(STARTTLS) 或 465(SSL)
#     Gmail    smtp.gmail.com   587(STARTTLS) 或 465(SSL)
#     Outlook  smtp.office365.com  587(STARTTLS)
#
# 【频率与安全控制】
#   APP_REGISTRATION_CODE_TTL_MINUTES    — 验证码有效期（分钟），默认 10
#   APP_REGISTRATION_SEND_INTERVAL_SECONDS — 同一邮箱重发最短间隔（秒），默认 60
#   APP_REGISTRATION_MAX_ATTEMPTS        — 验证码最大错误次数，超出后需重新获取，默认 5
# ============================================================================
APP_SMTP_HOST=smtp.qq.com
APP_SMTP_PORT=587
APP_SMTP_USER=your-email@qq.com
APP_SMTP_PASSWORD=your-smtp-authorization-code
APP_SMTP_FROM=your-email@qq.com
APP_SMTP_USE_TLS=true
APP_REGISTRATION_CODE_TTL_MINUTES=10
APP_REGISTRATION_SEND_INTERVAL_SECONDS=60
APP_REGISTRATION_MAX_ATTEMPTS=5
